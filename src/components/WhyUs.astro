---
const reasons = [
  {
    title: 'Transparent Pricing',
    desc: 'No hidden costs. Detailed estimates before work begins — you always know exactly what you\'re paying for.',
    icon: `<svg viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 4l16 6v12c0 9-8 16-16 18C14 38 6 31 6 22V10l16-6z"/>
      <path d="M15 22l5 5 9-9"/>
    </svg>`,
  },
  {
    title: 'On-Time Delivery',
    desc: 'We respect deadlines as much as we respect design. Every milestone is tracked, managed, and met.',
    icon: `<svg viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <circle cx="22" cy="22" r="17"/>
      <path d="M22 12v10l7 4"/>
    </svg>`,
  },
  {
    title: 'Premium Materials',
    desc: 'Only the finest materials sourced from trusted suppliers — because quality built in lasts a lifetime.',
    icon: `<svg viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 5l5 11h11l-9 7 3 11-10-7-10 7 3-11-9-7h11z"/>
    </svg>`,
  },
  {
    title: 'End-to-End Service',
    desc: 'From blueprint to handover, we manage everything — a single point of accountability for your entire project.',
    icon: `<svg viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 22h28M22 8v28"/>
      <circle cx="22" cy="22" r="18"/>
      <circle cx="22" cy="22" r="6"/>
    </svg>`,
  },
];
---

<section class="why">
  <div class="why-bg"></div>
  <div class="why-overlay"></div>

  <div class="why-inner">
    <div class="why-header" data-animate>
      <span class="section-label">Why Us</span>
      <h2 class="section-heading">Built on Trust,<br />Delivered with Precision</h2>
    </div>

    <div class="why-grid">
      {reasons.map((r, i) => (
        <div class="why-item" data-animate data-delay={String(i + 1)}>
          <div class="why-icon" set:html={r.icon} />
          <h3 class="why-title">{r.title}</h3>
          <p class="why-desc">{r.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why {
    position: relative;
    padding: var(--section-pad) 5vw;
    overflow: hidden;
  }
  .why-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1920&q=80');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  .why-overlay {
    position: absolute;
    inset: 0;
    background: rgba(13,13,13,0.88);
  }

  .why-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }
  .why-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .why-header .section-heading { color: var(--cream); }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.07);
  }

  .why-item {
    background: rgba(13,13,13,0.5);
    padding: 2.5rem 2rem;
    text-align: center;
    transition: background 0.3s;
  }
  .why-item:hover { background: rgba(13,13,13,0.7); }

  .why-icon {
    width: 44px; height: 44px;
    color: var(--red);
    margin: 0 auto 1.5rem;
  }
  .why-icon :global(svg) { width: 100%; height: 100%; }

  .why-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }
  .why-desc {
    font-size: 0.85rem;
    line-height: 1.75;
    color: var(--silver);
  }

  @media (max-width: 900px) {
    .why-grid { grid-template-columns: repeat(2, 1fr); }
    .why-bg { background-attachment: scroll; }
  }
  @media (max-width: 500px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
