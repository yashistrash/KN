---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const projects = [
  { name: 'Villa Serenity', category: 'residential', year: '2024', image: 'https://images.unsplash.com/photo-1613977257363-707ba9348227?w=700&q=80', alt: 'Villa Serenity exterior' },
  { name: 'The Meridian', category: 'interior', year: '2024', image: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=700&q=80', alt: 'The Meridian living room' },
  { name: 'Casa Nuvem', category: 'residential', year: '2023', image: 'https://images.unsplash.com/photo-1560185007-cde436f6a4d0?w=700&q=80', alt: 'Casa Nuvem bedroom' },
  { name: 'Apex Business Centre', category: 'commercial', year: '2024', image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=700&q=80', alt: 'Apex Business Centre office' },
  { name: 'The Garden Residence', category: 'residential', year: '2023', image: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=700&q=80', alt: 'The Garden Residence' },
  { name: 'Luxe Kitchen Redesign', category: 'interior', year: '2023', image: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=700&q=80', alt: 'Luxury kitchen redesign' },
  { name: 'Tambaram Office Park', category: 'commercial', year: '2022', image: 'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=700&q=80', alt: 'Tambaram Office Park' },
  { name: 'Heritage Bungalow Renewal', category: 'renovation', year: '2023', image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=700&q=80', alt: 'Heritage Bungalow Renewal' },
  { name: 'Sky Villa Penthouse', category: 'residential', year: '2024', image: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=700&q=80', alt: 'Sky Villa Penthouse' },
  { name: 'Modern Suite Interior', category: 'interior', year: '2022', image: 'https://images.unsplash.com/photo-1493809842364-78817add7ffb?w=700&q=80', alt: 'Modern suite interior' },
  { name: 'Retail Promenade', category: 'commercial', year: '2023', image: 'https://images.unsplash.com/photo-1528698827591-e19ccd7bc23d?w=700&q=80', alt: 'Retail Promenade' },
  { name: 'Complete Home Transformation', category: 'renovation', year: '2024', image: 'https://images.unsplash.com/photo-1484154218962-a197022b5858?w=700&q=80', alt: 'Complete home transformation kitchen' },
];

const categoryLabels: Record<string, string> = {
  residential: 'Residential',
  commercial: 'Commercial',
  interior: 'Interior Design',
  renovation: 'Renovation',
};
---

<Layout
  title="Projects | KN Architects & Builders"
  description="Explore KN Architects & Builders' portfolio of residential villas, commercial spaces, interior designs, and renovations across Chennai."
>
  <Nav activePage="projects" />

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Projects</span>
      </nav>
      <h1 class="page-hero-heading">Our Projects</h1>
      <p class="page-hero-sub">A decade of craftsmanship, vision, and precision</p>
    </div>
  </section>

  <!-- FILTER + GRID -->
  <section class="projects-section">
    <div class="projects-inner">
      <!-- Filter bar -->
      <div class="filter-bar" role="group" aria-label="Filter projects">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="residential">Residential</button>
        <button class="filter-btn" data-filter="commercial">Commercial</button>
        <button class="filter-btn" data-filter="interior">Interior Design</button>
        <button class="filter-btn" data-filter="renovation">Renovation</button>
      </div>

      <!-- Project grid -->
      <div class="projects-grid" id="projectsGrid">
        {projects.map((p, i) => (
          <div
            class="project-card"
            data-category={p.category}
            data-animate
            data-delay={String((i % 3) + 1)}
          >
            <div class="card-image">
              <img src={p.image} alt={p.alt} loading="lazy" width="600" height="400" />
            </div>
            <div class="card-overlay">
              <span class="card-cat">{categoryLabels[p.category]}</span>
              <span class="card-name">{p.name}</span>
            </div>
            <div class="card-meta">
              <span class="card-badge">{categoryLabels[p.category]}</span>
              <span class="card-year">{p.year}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <p class="empty-state" id="emptyState" style="display:none">
        No projects found in this category yet.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="projects-cta">
    <div class="cta-inner">
      <h2 class="cta-heading">Ready to Start Your Project?</h2>
      <p class="cta-sub">Book a free consultation and let's bring your vision to life.</p>
      <a href="/#contact" class="btn btn-primary">Book a Consultation</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    height: 46vh;
    min-height: 320px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=80');
    background-size: cover;
    background-position: center 40%;
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(13,13,13,0.78);
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    padding: 6rem 5vw 3rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    animation: fadeUp 0.9s ease 0.2s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--silver);
  }
  .breadcrumb a { color: var(--silver); transition: color 0.25s; }
  .breadcrumb a:hover { color: var(--cream); }
  .breadcrumb span:last-child { color: var(--red); }

  .page-hero-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 400;
    color: var(--cream);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .page-hero-sub {
    font-size: 1rem;
    color: var(--silver-light);
    font-weight: 300;
  }

  /* PROJECTS SECTION */
  .projects-section {
    background: var(--off-white);
    padding: 4rem 5vw 6rem;
  }
  .projects-inner { max-width: 1200px; margin: 0 auto; }

  /* Filter */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .filter-btn {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    border: 1px solid rgba(26,26,26,0.2);
    background: transparent;
    color: var(--gray);
    cursor: pointer;
    transition: all 0.25s;
  }
  .filter-btn:hover {
    border-color: var(--charcoal);
    color: var(--charcoal);
  }
  .filter-btn.active {
    background: var(--red);
    border-color: var(--red);
    color: white;
  }

  /* Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    background: white;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }
  .project-card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    transform: translateY(-4px);
  }
  .project-card.hidden { display: none; }

  .card-image {
    overflow: hidden;
    height: 240px;
  }
  .card-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.65s ease;
  }
  .project-card:hover .card-image img { transform: scale(1.06); }

  /* Hover overlay */
  .card-overlay {
    position: absolute;
    inset: 0 0 auto 0;
    height: 240px;
    background: linear-gradient(to top, rgba(13,13,13,0.88) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.35s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
  }
  .project-card:hover .card-overlay { opacity: 1; }
  .card-cat {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.25rem;
  }
  .card-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: white;
  }

  /* Card footer */
  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.1rem;
    background: white;
  }
  .card-badge {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
  }
  .card-year {
    font-size: 0.78rem;
    color: var(--silver);
    font-weight: 500;
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--silver);
    font-size: 1rem;
    font-style: italic;
  }

  /* CTA */
  .projects-cta {
    background: var(--black-deep);
    padding: 6rem 5vw;
    text-align: center;
  }
  .cta-inner { max-width: 560px; margin: 0 auto; }
  .cta-heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--cream);
    margin-bottom: 1rem;
  }
  .cta-sub {
    font-size: 0.95rem;
    color: var(--silver);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .projects-grid { grid-template-columns: 1fr; }
    .filter-bar { gap: 0.4rem; }
    .filter-btn { font-size: 0.65rem; padding: 0.5rem 1rem; }
  }
</style>

<script src="../scripts/animations.ts"></script>

<script>
  // Filter logic
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const emptyState = document.getElementById('emptyState')!;

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter!;
      let visibleCount = 0;

      cards.forEach((card) => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.classList.toggle('hidden', !match);
        if (match) visibleCount++;
      });

      emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });
</script>
